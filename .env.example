# Turso / libSQL connection
# Get these with: turso db show <db> --url  and  turso db tokens create <db>
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Single-password gate for the app
APP_PASSWORD=change-me

# Secret used to sign the session cookie (use a long random string, 32+ chars)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: local SQLite file path used only when TURSO_DATABASE_URL is unset
# BILLTRACK_DB_PATH=./data/billtrack.db
